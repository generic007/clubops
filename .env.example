APP_NAME=ClubOps
APP_ENV=production
APP_DEBUG=false
APP_URL=https://clubops.example.com

DB_CONNECTION=mysql
DB_HOST=mysql.example.dreamhost.com
DB_PORT=3306
DB_DATABASE=clubops_db
DB_USERNAME=clubops_user
DB_PASSWORD=

LOG_CHANNEL=daily
LOG_LEVEL=warning

FILESYSTEM_DISK=private
FILESYSTEM_CLOUD=

MAIL_MAILER=smtp
MAIL_HOST=smtp.dreamhost.com
MAIL_PORT=465
MAIL_USERNAME=noreply@clubops.example.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@clubops.example.com
MAIL_FROM_NAME="${APP_NAME}"

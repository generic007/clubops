APP_NAME=ClubOps
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=America/Los_Angeles

# Database: Use sqlite for local dev, mysql for DreamHost
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=mysql.clubops.example.com
# DB_PORT=3306
# DB_DATABASE=clubops_db
# DB_USERNAME=clubops_user
# DB_PASSWORD=***

# SQLite path (relative to database/ directory)
# DB_DATABASE=database.sqlite

LOG_LEVEL=debug
LOG_CHANNEL=stack

FILESYSTEM_DISK=private
FILESYSTEM_CLOUD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CACHE_DRIVER=file

QUEUE_CONNECTION=database
DB_QUEUE_TABLE=jobs

MAIL_MAILER=log
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.dreamhost.com
# MAIL_PORT=465
# MAIL_USERNAME=noreply@clubops.example.com
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=ssl
# MAIL_FROM_ADDRESS=noreply@clubops.example.com
# MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=localhost:8000
